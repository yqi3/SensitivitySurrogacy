Package: SensitivitySurrogacy
Title: Sensitivity Analysis and Partial Identification for Surrogate Index Methods
Version: 0.0.1
Authors@R: c(
    person("Yanqin", "Fan", email = "fany88@uw.edu", role = "aut"),
    person("Carlos A.", "Manzanares", email = "manzcarl@amazon.com", role = "aut"),
